{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "next-dev",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "--port", "3001"],
      "port": 3001
    },
    {
      "name": "styleguide",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const fs=require('fs'),http=require('http'),path=require('path');http.createServer((req,res)=>{const f=path.join('/Users/talia.b/Documents/Tenengroup-Sites-Design-System',req.url==='/'?'/styleguide.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end('Not found')}else{res.writeHead(200,{'Content-Type':f.endsWith('.html')?'text/html':f.endsWith('.json')?'application/json':'text/plain'});res.end(d)}})}).listen(3333)"],
      "port": 3333
    }
  ]
